{
  "headers": [
    {
      "source": "/(.*)\\.(js|css|woff2|woff|ttf|otf|webp|jpg|jpeg|png|svg|mp3)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
